# Google OAuth Configuration
# Obtén tu Google Client ID en: https://console.cloud.google.com/
# 1. Crea un nuevo proyecto en Google Cloud Console
# 2. Habilita Google+ API
# 3. Crea una credencial de tipo "OAuth 2.0 Client IDs for Web application"
# 4. Agrega http://localhost:5173 a los orígenes autorizados
# 5. Copia el Client ID en la variable VITE_GOOGLE_CLIENT_ID

VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Supabase Configuration
# Obtén tus credenciales en: https://supabase.com
# 1. Crea una cuenta en Supabase
# 2. Crea un nuevo proyecto (nombre: maslaconnect)
# 3. Ve a Settings → API
# 4. Copia Project URL en VITE_SUPABASE_URL
# 5. Copia Project API Key (anon public) en VITE_SUPABASE_ANON_KEY
# 6. Ver SUPABASE_SETUP.md para pasos completos

VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend Email Service Configuration (opcional)
# Obtén tu API key en: https://resend.com
# Deja vacío para desactivar notificaciones por email
# 1. Ve a https://resend.com
# 2. Crea una cuenta o inicia sesión
# 3. Copia tu API key en la variable VITE_RESEND_API_KEY

VITE_RESEND_API_KEY=re_your_api_key_here
